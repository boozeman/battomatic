FROM python:3.12-slim

ENV PYTHONPATH="/usr/bin/python3"
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /battomatic

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential default-libmysqlclient-dev pkg-config netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

ADD requirements.txt requirements.txt
RUN pip install --upgrade pip
RUN pip install --no-cache-dir -r requirements.txt

COPY . /battomatic/

EXPOSE 3005
ENTRYPOINT ["/battomatic/entrypoint.sh"]
CMD ["gunicorn", "battomatic.wsgi:application", "--bind", "0.0.0.0:3005", "--workers", "3"]
